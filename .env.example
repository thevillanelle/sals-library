VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# When the user with VITE_LIBRARY_ALIAS_UID logs in, the app reads/writes
# VITE_LIBRARY_OWNER_UID's library data instead of their own (unless they
# toggle to "standard view"). Optional — omit both to disable aliasing.
VITE_LIBRARY_OWNER_UID=00000000-0000-0000-0000-000000000000
VITE_LIBRARY_ALIAS_UID=00000000-0000-0000-0000-000000000000
